# ChromaDB connection
# Leave CHROMA_HOST unset to use a local persistent database instead.

# Remote ChromaDB server
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_SSL=false
# CHROMA_AUTH_TOKEN=your-token-here

# Local persistent store (used when CHROMA_HOST is not set)
# CHROMA_DB_PATH=.chroma_db

# Collection name (default: openapi_specs)
# CHROMA_COLLECTION=openapi_specs

# Sentence-transformers embedding model
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB connection
# Leave CHROMA_HOST unset to use a local persistent database instead.

# Remote ChromaDB server
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_SSL=false
# CHROMA_AUTH_TOKEN=your-token-here

# Local persistent store (used when CHROMA_HOST is not set)
# CHROMA_DB_PATH=.chroma_db

# Collection name (default: openapi_specs)
# CHROMA_COLLECTION=openapi_specs

# Sentence-transformers embedding model
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Ollama embedding
# OLLAMA_URL=
# OLLAMA_MODEL=mxbai-embed-large

# Authentication (only enforced when NODE_ENV=production)
# MCP_ADMIN_TOKEN=your-admin-token
# MCP_READ_TOKEN=your-read-token

# Chat LLM provider
# LLM_PROVIDER=anthropic        # "anthropic" | "ollama"
# LLM_MODEL=claude-sonnet-4-20250514  # or "qwen3:14b" for ollama
# ANTHROPIC_API_KEY=sk-...       # required if provider is anthropic

# GIF reactions (optional — get a free key from developers.giphy.com)
# GIPHY_API_KEY=your-giphy-api-key

# Environment
# NODE_ENV=development
